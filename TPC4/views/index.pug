extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Lista de exames médicos desportivos
    
    .w3-container
      .w3-margin-top
        a.w3-btn.w3-teal(href='/?sort=data') Ordenar por Data ↓
        a.w3-btn.w3-blue.w3-margin-left(href='/?sort=nome') Ordenar por Nome ↑
        a.w3-btn.w3-purple.w3-margin-left(href='/emd/registo') + Novo EMD
        a.w3-btn.w3-orange.w3-margin-left(href='/emd/stats') Estatísticas
      table.w3-table-all.w3-margin-top
        tr
          th Nome
          th Data
          th Modalidade
          th Resultado
          th Ações
        each t in list
          tr
            td
              a(href=`/emd/${t.id}`)= t.nome.primeiro + " " + t.nome['último']
            td= t.dataEMD
            td= t.modalidade
            td= t.resultado ? "Aprovado" : "Reprovado"
            td
              a.w3-btn.w3-blue.w3-small(href=`/emd/editar/${t.id}`) Editar
              a.w3-btn.w3-red.w3-small.w3-margin-left(href=`/emd/apagar/${t.id}`) Apagar
        