extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Lista de exames médicos desportivos
    
    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th Nome
          th Data
          th Modalidade
          th Resultado
        each t in list
          tr
            td
              a(href='/atletas/' + t._id)= t.nome.primeiro + " " + t.nome['último']
            td= t.dataEMD
            td= t.modalidade
            td= t.resultado
        