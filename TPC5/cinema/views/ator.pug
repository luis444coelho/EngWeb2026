extends layout

block content
  .w3-card-4

    header.w3-container.w3-teal
      h2 Detalhes do Ator

    .w3-container.w3-padding

      p
        b ID:
        |  #{ator.id}

      p
        b Nome:
        |  #{ator.nome}

      p
        b Número de Filmes:
        |  #{filmes.length}

      p
        b Filmes:
      ul
        each filme in filmes
          li: a(href=`/filmes/${filme.id}`)= filme.title

      br

      a.w3-btn.w3-grey(href="/atores") Voltar para Atores
      |  
      a.w3-btn.w3-grey(href="/") Voltar para Início