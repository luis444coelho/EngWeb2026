extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Atores List 
    
    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th Id
          th Nome

        each e in list
          tr
            td: a(href=`/atores/${e.id}`)= e.id
            td: a(href=`/atores/${e.id}`)= e.nome

      br
      a.w3-btn.w3-grey(href="/") Voltar