extends layout

block content
  .w3-card-4

    header.w3-container.w3-teal
      h2 Detalhes do Filme

    .w3-container.w3-padding

      p
        b ID:
        |  #{filme.id}

      p
        b Título:
        |  #{filme.title}

      p
        b Ano:
        |  #{filme.year}

      p
        b Elenco:
        |  #{filme.cast.join(', ')}

      p
        b Géneros:
        |  #{filme.genres.join(', ')}

      br

      a.w3-btn.w3-grey(href="/") Voltar
