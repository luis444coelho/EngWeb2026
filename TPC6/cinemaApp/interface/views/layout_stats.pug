doctype html
html
  head
    title Estatísticas dos Exames Médico-Desportivos
    meta(charset='UTF-8')
    link(rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>💓</text></svg>")
    link(rel='stylesheet' href='/stylesheets/style.css')
    script(src="/javascripts/chart.js")
  body
    block content
    footer.w3-container.w3-teal.w3-margin-top
      h5 Generated by 
        a(href='https://epl.di.uminho.pt/~jcr/AULAS/EngWeb2026/') EngWeb2026, #{date}

    script. 
      // Passar dados do Pug para o JavaScript do browser
      const stats = !{JSON.stringify(stats)};

      function createChart(id, label, dataObj, type = 'pie') {
        new Chart(document.getElementById(id), {
          type: type,
          data: {
          labels: Object.keys(dataObj),
          datasets: [{
            label: label,
            data: Object.values(dataObj),
            backgroundColor: ['#009688', '#ff5722', '#2196F3', '#ffeb3b', '#9c27b0', '#4caf50', '#e91e63', '#00bcd4', '#8bc34a', '#ffc107']
          }]},
          options: { 
            responsive: true,
            maintainAspectRatio: true,
            plugins: { title: { display: true, text: label } } }
          });
      }

      window.onload = function() {
        createChart('chartModalidade', 'Distribuição por Modalidade', stats.modalidade, 'bar');
        createChart('chartClube', 'Distribuição por Clube', stats.clube, 'bar');
        createChart('chartGenero', 'Distribuição por Sexo', stats.genero, 'pie');
      }
      
      
      