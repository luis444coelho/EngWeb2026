extends layout_stats

block content
    .w3-card-4
        header.w3-container.w3-teal
            h2 Estatísticas dos Exames Médico-Desportivos
            
        div.w3-container.w3-padding-16
            div.w3-row-padding
                // Gráfico por Modalidade
                div.w3-half.w3-margin-bottom(style="max-width: 50%;")
                    canvas#chartModalidade
                // Gráfico por Clube
                div.w3-half.w3-margin-bottom(style="max-width: 50%;")
                    canvas#chartClube
                // Gráfico por Sexo/Género
                div.w3-half.w3-margin-bottom(style="max-width: 50%;")
                    canvas#chartGenero

    